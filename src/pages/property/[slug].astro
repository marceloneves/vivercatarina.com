---
import { getPropertySlugRedirects } from '../../lib/property-slug-redirects.mjs';

export function getStaticPaths() {
	const redirects = getPropertySlugRedirects();

	return Object.entries(redirects).map(([oldSlug, newSlug]) => ({
		params: { slug: oldSlug },
		props: { redirectTo: `/imovel/${newSlug}` },
	}));
}

const { redirectTo } = Astro.props;

return Astro.redirect(redirectTo, 301);
---
