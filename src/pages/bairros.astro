---
import PillerLayout from '../layouts/PillerLayout.astro';
import HomeBairrosSection from '../components/HomeBairrosSection.astro';
import bodyHtml from '../content/template-pages/bairros.html?raw';
import { removeBreadcrumbTitle, stripBreadcrumbHero } from '../lib/listing-breadcrumb.mjs';
import { applySemanticHtml, wrapSplitPageContent } from '../lib/semantic-html.mjs';
import { loadHomeNeighborhoodCards } from '../lib/home-page.mjs';
import { patchSiteMenu } from '../lib/site-menu.mjs';
import { buildKeywords, resolvePageSeo } from '../lib/site-seo.mjs';

const seo = resolvePageSeo({ title: 'Bairros', pathname: '/bairros' });
const title = 'Bairros';
const bodyClass = 'bairro-listing';
const description = seo.description;

const contentStart = bodyHtml.indexOf('<!--==============================\nBlog Area');
const footerStart = bodyHtml.indexOf('<!--==============================\n\tFooter Area');

if (contentStart === -1 || footerStart === -1) {
	throw new Error('Não foi possível montar a página de bairros a partir do template.');
}

const shell = wrapSplitPageContent(
	stripBreadcrumbHero(
		removeBreadcrumbTitle(
			patchSiteMenu(applySemanticHtml(bodyHtml.slice(0, contentStart)), '/bairros'),
		),
	),
	applySemanticHtml(bodyHtml.slice(footerStart)),
);

const neighborhoodCards = loadHomeNeighborhoodCards();
---

<PillerLayout
	title={title}
	bodyClass={bodyClass}
	description={description}
	keywords={buildKeywords('bairros Florianópolis', 'imóveis na planta', 'lançamentos por bairro')}
	canonicalPath="/bairros"
	disableEffects
	stylesheets={['/css/internal-links.css']}
>
	<Fragment set:html={shell.before} />
	<HomeBairrosSection neighborhoods={neighborhoodCards} variant="listing" />
	<Fragment set:html={shell.after} />
</PillerLayout>
