---
import PillerLayout from '../../layouts/PillerLayout.astro';
import bodyHtml from '../../content/template-pages/blog-details.html?raw';
import { applyArticleInlineLinks } from '../../lib/blog-content-links.mjs';
import { getBlogPost, getBlogPostMetaDescription, getBlogPosts } from '../../lib/blog-posts.mjs';
import { patchCompactListingBreadcrumb } from '../../lib/listing-breadcrumb.mjs';
import { applySemanticHtml, wrapSplitPageContent } from '../../lib/semantic-html.mjs';
import { buildKeywords } from '../../lib/site-seo.mjs';

export function getStaticPaths() {
	return getBlogPosts().map((post) => ({
		params: { slug: post.slug },
	}));
}

const { slug } = Astro.params;
const post = getBlogPost(slug);

if (!post) {
	return Astro.redirect('/blog', 301);
}

if (post.href === '/blog' && slug !== 'blog') {
	return Astro.redirect('/blog', 301);
}

const title = post.title;
const blogBody = applyArticleInlineLinks('', slug);

const blogAreaStart = bodyHtml.indexOf('<!--==============================\n        Blog Area');
const articleStart = bodyHtml.indexOf('<article class="th-blog blog-single">');
const articleEnd = bodyHtml.indexOf('</article>', articleStart);

const footerStart = bodyHtml.indexOf('<!--==============================\n\tFooter Area');

if (blogAreaStart === -1 || articleStart === -1 || articleEnd === -1 || footerStart === -1) {
	throw new Error('Não foi possível montar o artigo do blog a partir do template.');
}

const shell = wrapSplitPageContent(
	applySemanticHtml(
		patchCompactListingBreadcrumb(bodyHtml.slice(0, blogAreaStart), {
			pageLabel: title,
			parent: { href: '/blog', label: 'Blog' },
		}),
	),
	applySemanticHtml(bodyHtml.slice(footerStart)),
);

const articleBlock = bodyHtml
	.slice(articleStart, articleEnd + '</article>'.length)
	.replace(
		'Building gains into housing stocks and how to trade the sector',
		post.title,
	)
	.replace('Michel Smith', post.author)
	.replace('24/02/2025', post.dateLabel)
	.replace('Business', post.category)
	.replace('src="/assets/img/blog/blog-s-1-1.jpg"', `src="${post.imageUrl}"`)
	.replace('alt="Image"', `alt="${post.title}"`)
	.replace(
		'<!-- BLOG_BODY -->',
		`<div class="blog-article-body">${blogBody}</div>`,
	)
	.replace(
		'<span class="share-links-title">Tags:</span>',
		'<span class="share-links-title">Tags</span>',
	)
	.replace(
		'<a href="/blog">luxury home</a>\n                                            <a href="/blog">Strategey</a>\n                                            <a href="/blog">Villa Home</a>\n                                            <a href="/blog">Project</a>',
		(post.tags ?? [])
			.map((tag) => `<a href="/blog">${tag}</a>`)
			.join('\n                                            '),
	)
	.replace(
		'<span class="share-links-title">Share this article:</span>',
		'<span class="share-links-title">Compartilhar</span>',
	);

const articleHtml = applySemanticHtml(`<!--==============================
        Blog Area
    ==============================-->
    <section class="th-blog-wrapper blog-details space-top space-extra-bottom">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-xl-10 col-xxl-9">
                    ${articleBlock}
                </div>
            </div>
        </div>
    </section>`);
---

<PillerLayout
	title={title}
	description={getBlogPostMetaDescription(post)}
	keywords={buildKeywords(title, post.category, ...(post.tags ?? []), 'blog imobiliário Florianópolis')}
	ogImage={post.imageUrl}
	ogType="article"
	canonicalPath={`/blog/${slug}`}
	bodyClass="blog-article-page"
	stylesheets={['/css/blog-article.css', '/css/internal-links.css']}
>
	<Fragment set:html={shell.before} />
	<Fragment set:html={articleHtml} />
	<Fragment set:html={shell.after} />
</PillerLayout>
