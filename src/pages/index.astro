---
import PillerLayout from '../layouts/PillerLayout.astro';
import HomePropertySearch from '../components/HomePropertySearch.astro';
import HomeBairrosSection from '../components/HomeBairrosSection.astro';
import HomeBlogSection from '../components/HomeBlogSection.astro';
import HomeFaqSection from '../components/HomeFaqSection.astro';
import HomeLancamentosSection from '../components/HomeLancamentosSection.astro';
import { getBlogPosts } from '../lib/blog-posts.mjs';
import { buildHomeFaqSchema, getHomeFaqItems } from '../lib/home-faq.mjs';
import {
	getHomeNeighborhoodOptions,
	getHomePageShell,
	getHomePropertyKindOptions,
	loadHomeFeaturedLancamentos,
	loadHomeNeighborhoodCards,
} from '../lib/home-page.mjs';

const title = 'Início';
const bodyClass = 'home-page';
const shell = getHomePageShell();
const propertyKindOptions = getHomePropertyKindOptions();
const neighborhoodOptions = getHomeNeighborhoodOptions();
const featuredLancamentos = loadHomeFeaturedLancamentos(4);
const neighborhoodCards = loadHomeNeighborhoodCards();
const latestPosts = getBlogPosts().slice(0, 3);
const homeFaqItems = getHomeFaqItems();
const homeFaqSchema = buildHomeFaqSchema();
---

<PillerLayout title={title} bodyClass={bodyClass} disableEffects>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(homeFaqSchema)} />
	</Fragment>
	<Fragment set:html={shell.before} />
	<HomePropertySearch kinds={propertyKindOptions} neighborhoods={neighborhoodOptions} />
	<HomeLancamentosSection
		properties={featuredLancamentos}
		kinds={propertyKindOptions}
		neighborhoods={neighborhoodOptions}
	/>
	<HomeBairrosSection neighborhoods={neighborhoodCards} />
	<HomeBlogSection posts={latestPosts} />
	<HomeFaqSection items={homeFaqItems} />
	<Fragment set:html={shell.after} />
</PillerLayout>
