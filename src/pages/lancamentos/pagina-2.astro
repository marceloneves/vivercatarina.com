---
import PillerLayout from '../../layouts/PillerLayout.astro';
import bodyHtml from '../../content/template-pages/lancamentos/pagina-2.html?raw';
import {
	buildLancamentosIntroHtml,
	injectListingIntroInHtml,
} from '../../lib/blog-content-links.mjs';

const title = 'Lançamentos';
const bodyClass = 'bairro-listing';
const processedHtml = injectListingIntroInHtml(bodyHtml, buildLancamentosIntroHtml(''));
---

<PillerLayout
	title={title}
	bodyClass={bodyClass}
	disableEffects
	stylesheets={['/css/internal-links.css']}
>
	<Fragment set:html={processedHtml} />
</PillerLayout>
