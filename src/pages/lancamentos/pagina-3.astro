---
import PillerLayout from '../../layouts/PillerLayout.astro';
import bodyHtml from '../../content/template-pages/lancamentos/pagina-3.html?raw';
import { patchLancamentosTemplateHtml } from '../../lib/listing-breadcrumb.mjs';
import { applySemanticHtml } from '../../lib/semantic-html.mjs';
import { patchSiteMenu } from '../../lib/site-menu.mjs';

const title = 'Lançamentos';
const bodyClass = 'bairro-listing';
const html = patchSiteMenu(
	patchLancamentosTemplateHtml(applySemanticHtml(bodyHtml)),
	'/lancamentos/pagina-3',
);
---

<PillerLayout title={title} bodyClass={bodyClass} disableEffects>
	<Fragment set:html={html} />
</PillerLayout>
