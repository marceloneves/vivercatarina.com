---
import PillerLayout from '../layouts/PillerLayout.astro';
import AboutPageContent from '../components/AboutPageContent.astro';
import bodyHtml from '../content/template-pages/about.html?raw';
import { removeBreadcrumbTitle, stripBreadcrumbHero } from '../lib/listing-breadcrumb.mjs';
import { applySemanticHtml, wrapSplitPageContent } from '../lib/semantic-html.mjs';
import { patchSiteMenu } from '../lib/site-menu.mjs';

const title = 'Quem Somos';
const bodyClass = '';

const aboutAreaStart = bodyHtml.indexOf('<!--==============================\nAbout Area');
const footerStart = bodyHtml.indexOf('<!--==============================\n\tFooter Area');

if (aboutAreaStart === -1 || footerStart === -1) {
	throw new Error('Não foi possível montar a página Quem Somos a partir do template.');
}

const shell = wrapSplitPageContent(
	stripBreadcrumbHero(
		removeBreadcrumbTitle(
			patchSiteMenu(applySemanticHtml(bodyHtml.slice(0, aboutAreaStart)), '/about'),
		),
	),
	applySemanticHtml(bodyHtml.slice(footerStart)),
);
---

<PillerLayout title={title} bodyClass={bodyClass} stylesheets={['/css/internal-links.css']}>
	<Fragment set:html={shell.before} />
	<AboutPageContent />
	<Fragment set:html={shell.after} />
</PillerLayout>
