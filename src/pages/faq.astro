---
import PillerLayout from '../layouts/PillerLayout.astro';
import bodyHtml from '../content/template-pages/faq.html?raw';
import { applySemanticHtml } from '../lib/semantic-html.mjs';

const title = 'FAQS';
const bodyClass = '';
const html = applySemanticHtml(bodyHtml);
---

<PillerLayout title={title} bodyClass={bodyClass} stylesheets={['/css/internal-links.css']}>
	<Fragment set:html={html} />
</PillerLayout>
