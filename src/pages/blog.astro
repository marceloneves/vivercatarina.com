---
import PillerLayout from '../layouts/PillerLayout.astro';
import BlogLancamentosScContent from '../components/BlogLancamentosScContent.astro';
import bodyHtml from '../content/template-pages/blog.html?raw';
import { buildBlogLancamentosScDefinedTermSet } from '../lib/blog-lancamentos-sc-terms.mjs';
import { SITE_URL } from '../lib/site-contact.mjs';
import { applySemanticHtml, wrapSplitPageContent } from '../lib/semantic-html.mjs';
import { patchSiteMenu } from '../lib/site-menu.mjs';
import { buildKeywords, resolvePageSeo } from '../lib/site-seo.mjs';

const seo = resolvePageSeo({
	title: 'Termos de lançamentos em Santa Catarina',
	pathname: '/blog',
});
const title = seo.title;
const description = seo.description;
const bodyClass = '';

const blogAreaStart = bodyHtml.indexOf('<!--==============================\nBlog Area\n==============================-->');
const footerStart = bodyHtml.indexOf('<!--==============================\n\tFooter Area');

if (blogAreaStart === -1 || footerStart === -1) {
	throw new Error('Não foi possível montar a página do blog a partir do template.');
}

const shell = wrapSplitPageContent(
	patchSiteMenu(applySemanticHtml(bodyHtml.slice(0, blogAreaStart)), '/blog'),
	applySemanticHtml(bodyHtml.slice(footerStart)),
);

const definedTermSet = buildBlogLancamentosScDefinedTermSet(SITE_URL, description);
---

<PillerLayout
	title={title}
	bodyClass={bodyClass}
	description={description}
	keywords={buildKeywords(
		'lançamentos Santa Catarina',
		'termos imobiliários SC',
		'comprar na planta',
		'Vale do Itajaí',
		'incorporação imobiliária',
	)}
	canonicalPath="/blog"
	stylesheets={['/css/internal-links.css']}
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(definedTermSet)} />
	</Fragment>
	<Fragment set:html={shell.before} />
	<BlogLancamentosScContent />
	<Fragment set:html={shell.after} />
</PillerLayout>
