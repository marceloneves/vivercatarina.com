---
import PillerLayout from '../layouts/PillerLayout.astro';
import bodyHtml from '../content/template-pages/agency.html?raw';
import { applySemanticHtml } from '../lib/semantic-html.mjs';

const title = "Agencies";
const bodyClass = "";
const html = applySemanticHtml(bodyHtml);
---

<PillerLayout title={title} bodyClass={bodyClass}>
	<Fragment set:html={html} />
</PillerLayout>
