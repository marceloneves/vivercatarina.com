---
const { name, paragraphs, hasProperties } = Astro.props;
---

<div class="bairro-intro-panel" aria-label={`Sobre imóveis na planta em ${name}`}>
	{
		paragraphs.map((paragraph, index) => (
			<p
				class:list={[
					'bairro-intro-panel__text',
					index === paragraphs.length - 1 && !hasProperties && 'mb-0',
				]}
			>
				{paragraph}
			</p>
		))
	}
	{
		!hasProperties && (
			<p class="bairro-intro-panel__note mb-0">
				No momento não há lançamentos publicados para {name}.{' '}
				<a href="/contato">Fale conosco</a> ou veja outros{' '}
				<a href="/bairros">bairros de Florianópolis</a>.
			</p>
		)
	}
</div>
