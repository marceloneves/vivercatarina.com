---
const { post } = Astro.props;
---

<article class="blog-card blog-post-card">
	<div class="blog-img">
		<a href={post.href}>
			<img src={post.imageUrl} alt={post.title} loading="lazy" />
		</a>
		<div class="date">
			<time datetime={post.datePublished}>
				<a href="/blog">{post.dateLabel}</a>
			</time>
		</div>
	</div>
	<div class="blog-content">
		<div class="blog-meta">
			<a href="/blog">
				<i class="fa-solid fa-user" aria-hidden="true"></i> {post.author}
			</a>
		</div>
		<h3 class="box-title">
			<a href={post.href}>{post.title}</a>
		</h3>
		<p class="box-text">{post.excerpt}</p>
		<a href={post.href} class="th-btn pill blog-post-card__read-btn">Ler artigo</a>
	</div>
</article>

<style>
	.blog-post-card {
		display: flex;
		flex-direction: column;
		width: 100%;
		height: 100%;
		border: 1px solid var(--th-border-color);
		border-radius: 12px;
		overflow: hidden;
		background: var(--white-color);
		box-shadow: 0 2px 12px rgba(17, 24, 39, 0.05);
		transition:
			box-shadow 0.2s ease,
			border-color 0.2s ease;
	}

	.blog-post-card:hover {
		box-shadow: 0 6px 24px rgba(17, 24, 39, 0.08);
		border-color: color-mix(in srgb, var(--theme-color) 35%, var(--th-border-color));
	}

	.blog-post-card :global(.blog-img) {
		flex-shrink: 0;
		height: 220px;
		border-radius: 0;
	}

	.blog-post-card :global(.blog-img img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.blog-post-card :global(.blog-img .date) {
		padding: 12px 14px;
	}

	.blog-post-card :global(.blog-img .date a) {
		font-size: 14px;
	}

	.blog-post-card :global(.blog-content) {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 20px 20px 24px;
	}

	.blog-post-card :global(.box-title) {
		display: -webkit-box;
		overflow: hidden;
		margin-bottom: 12px;
		font-size: 18px;
		line-height: 1.35;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		line-clamp: 3;
	}

	.blog-post-card :global(.box-text) {
		display: -webkit-box;
		overflow: hidden;
		margin-bottom: 0;
		font-size: 15px;
		line-height: 1.55;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		line-clamp: 3;
	}

	.blog-post-card :global(.blog-content .th-btn.blog-post-card__read-btn) {
		align-self: flex-start;
		margin-top: auto;
		padding: 9px 18px;
		min-width: 0;
		font-size: 13px;
		font-weight: 600;
		line-height: 1.2;
		text-transform: none;
	}
</style>
