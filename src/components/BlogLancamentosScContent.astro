---
import { applyGlossaryInlineLinks } from '../lib/glossary-content-links.mjs';
import { getBlogLancamentosScTermGroups } from '../lib/blog-lancamentos-sc-terms.mjs';

const groups = getBlogLancamentosScTermGroups().map((group) => ({
	...group,
	terms: group.terms.map(({ term, slug, definition }) => ({
		term,
		slug,
		definition: applyGlossaryInlineLinks(definition, {
			excludeSlugs: [slug],
			skipHeadings: false,
		}),
	})),
}));

const introText = applyGlossaryInlineLinks(
	'Guia do Viver Catarina com os principais termos de lançamentos imobiliários em Santa Catarina. Do Vale do Itajaí à Grande Florianópolis, do pré-lançamento ao habite-se: entenda o vocabulário do mercado catarinense antes de comparar empreendimentos na planta.',
	{ skipHeadings: false },
);
---

<nav class="breadcumb-wrapper single-inventory" aria-label="Trilha de navegação">
	<div class="container">
		<div class="breadcumb-content">
			<ol class="breadcumb-menu">
				<li><a href="/">Início</a></li>
				<li><span aria-current="page">Blog</span></li>
			</ol>
		</div>
	</div>
</nav>

<section class="space overflow-hidden blog-terms-page" aria-labelledby="blog-terms-title">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-xl-10 col-lg-11">
				<div class="title-area text-center mb-40">
					<p class="sub-title"><span class="double-line"></span> Santa Catarina</p>
					<h1 class="sec-title" id="blog-terms-title">
						Termos de lançamentos imobiliários em Santa Catarina
					</h1>
					<p class="sec-text blog-terms-intro" set:html={introText} />
				</div>

				<nav class="blog-terms-categories" aria-label="Seções do guia">
					{
						groups.map((group) => (
							<a class="blog-terms-category-link" href={`#${group.id}`}>
								{group.title}
							</a>
						))
					}
				</nav>

				<div class="blog-terms-toolbar">
					<label class="blog-terms-search-label" for="blog-terms-search">Buscar termo</label>
					<input
						id="blog-terms-search"
						class="form-control blog-terms-search"
						type="search"
						placeholder="Ex.: patrimônio de afetação, Vale do Itajaí, habite-se..."
						autocomplete="off"
					/>
				</div>

				<div class="blog-terms-groups" id="blog-terms-list">
					{
						groups.map((group) => (
							<section class="blog-terms-group" id={group.id} data-group={group.id}>
								<h2 class="blog-terms-group-title">{group.title}</h2>
								<dl class="blog-terms-list">
									{
										group.terms.map(({ term, slug, definition }) => (
											<div
												class="blog-terms-item"
												data-term={term.toLocaleLowerCase('pt-BR')}
												data-group={group.id}
											>
												<dt class="blog-terms-term" id={slug}>
													<a href={`#${slug}`}>{term}</a>
												</dt>
												<dd class="blog-terms-definition-wrap">
													<p class="blog-terms-definition" set:html={definition} />
												</dd>
											</div>
										))
									}
								</dl>
							</section>
						))
					}
				</div>

				<p class="blog-terms-empty" id="blog-terms-empty" hidden>
					Nenhum termo encontrado para a busca.
				</p>

				<div class="blog-terms-cta text-center">
					<p class="sec-text mb-3">
						Quer comparar lançamentos nas principais cidades de SC ou tirar dúvidas sobre um
						empreendimento?
					</p>
					<a href="/" class="th-btn style2 pill me-2 mb-2">Ver cidades</a>
					<a href="/contact" class="th-btn pill mb-2">Falar conosco</a>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const searchInput = document.getElementById('blog-terms-search');
	const items = Array.from(document.querySelectorAll('.blog-terms-item'));
	const groups = Array.from(document.querySelectorAll('.blog-terms-group'));
	const emptyState = document.getElementById('blog-terms-empty');

	function normalize(value) {
		return String(value || '')
			.normalize('NFD')
			.replace(/[\u0300-\u036f]/g, '')
			.toLowerCase();
	}

	function filterTerms() {
		const query = normalize(searchInput?.value || '');
		let visibleCount = 0;

		for (const item of items) {
			const term = normalize(item.getAttribute('data-term'));
			const definition = normalize(item.querySelector('.blog-terms-definition')?.textContent);
			const visible = !query || term.includes(query) || definition.includes(query);

			item.hidden = !visible;
			if (visible) {
				visibleCount += 1;
			}
		}

		for (const group of groups) {
			const hasVisibleItems = group.querySelector('.blog-terms-item:not([hidden])');
			group.hidden = !hasVisibleItems;
		}

		if (emptyState) {
			emptyState.hidden = visibleCount > 0;
		}
	}

	searchInput?.addEventListener('input', filterTerms);
</script>

<style>
	.blog-terms-intro {
		max-width: 760px;
		margin-inline: auto;
	}

	.blog-terms-categories {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
		margin-bottom: 1.75rem;
	}

	.blog-terms-category-link {
		display: inline-flex;
		align-items: center;
		padding: 0.45rem 1rem;
		border-radius: 999px;
		background: var(--smoke-color, #f5f5f5);
		color: var(--title-color);
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		transition: background-color 0.2s ease, color 0.2s ease;
	}

	.blog-terms-category-link:hover {
		background: var(--theme-color);
		color: #fff;
	}

	.blog-terms-toolbar {
		margin-bottom: 2.5rem;
	}

	.blog-terms-search-label {
		display: block;
		margin-bottom: 0.5rem;
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--title-color);
	}

	.blog-terms-search {
		min-height: 52px;
		border-radius: 999px;
		padding-inline: 1.25rem;
	}

	.blog-terms-group + .blog-terms-group {
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(3, 6, 14, 0.08);
	}

	.blog-terms-group-title {
		margin-bottom: 1.25rem;
		font-size: 1.5rem;
		line-height: 1.25;
		color: var(--theme-color);
	}

	.blog-terms-list {
		margin: 0;
	}

	.blog-terms-item + .blog-terms-item {
		margin-top: 1.25rem;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(3, 6, 14, 0.06);
	}

	.blog-terms-term {
		margin: 0 0 0.5rem;
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--title-color);
	}

	.blog-terms-term a {
		color: inherit;
		text-decoration: none;
	}

	.blog-terms-term a:hover {
		color: var(--theme-color);
	}

	.blog-terms-definition-wrap {
		margin: 0;
	}

	.blog-terms-definition {
		margin: 0;
		color: var(--body-color);
		line-height: 1.7;
	}

	.blog-terms-definition :global(a) {
		color: var(--theme-color);
		font-weight: 600;
		text-decoration: none;
	}

	.blog-terms-definition :global(a:hover) {
		text-decoration: underline;
	}

	.blog-terms-empty {
		margin: 0 0 2rem;
		text-align: center;
		color: var(--body-color);
	}

	.blog-terms-cta {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(3, 6, 14, 0.08);
	}
</style>
