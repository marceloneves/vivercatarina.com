---
import {
	SITE_EMAIL,
	SITE_NAME,
	SITE_PHONE_DISPLAY,
	SITE_WHATSAPP_NUMBER,
} from '../lib/site-contact.mjs';

const differentiators = [
	{
		title: 'Foco exclusivo em SC',
		text: 'Não somos um portal nacional que trata Santa Catarina como mais um estado. Somos catarinenses, conhecemos cada cidade que cobrimos e entendemos o mercado local como ninguém.',
		icon: '/assets/img/icon/about-1-1.svg',
	},
	{
		title: 'Especialistas em lançamentos',
		text: 'Trabalhamos exclusivamente com pré-lançamentos, lançamentos e imóveis recém-entregues. Nosso foco é o imóvel novo — e nisso somos referência.',
		icon: '/assets/img/icon/about-1-2.svg',
	},
	{
		title: 'Informação de qualidade',
		text: `Cada empreendimento cadastrado no ${SITE_NAME} passa pela nossa curadoria. Plantas, preços, destaques e localização — tudo verificado e apresentado de forma clara.`,
		icon: '/assets/img/icon/about-1-3.svg',
	},
	{
		title: 'Tecnologia a serviço do comprador',
		text: 'Usamos inteligência artificial para manter as informações sempre atualizadas e para entregar ao comprador exatamente o que ele precisa saber antes de tomar uma decisão.',
		icon: '/assets/img/icon/about-1-4.svg',
	},
	{
		title: 'Cobertura das 25 maiores cidades',
		text: 'De Joinville a Criciúma, de Balneário Camboriú a Chapecó — cobrimos as 25 maiores cidades de Santa Catarina com páginas dedicadas, informações locais e lançamentos verificados.',
		icon: '/assets/img/icon/about-3-1.svg',
	},
];

const stats = [
	{ value: '25', label: 'cidades cobertas em SC' },
	{ value: '6', label: 'regiões do estado' },
	{ value: '3', label: 'categorias de imóvel' },
	{ value: '1', label: 'missão: conectar você ao seu próximo lar' },
];
---

<div class="about-1-wrapper space overflow-hidden" id="about-sec">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-xl-10 col-lg-11">
				<div class="title-area text-center mb-40">
					<p class="sub-title"><span class="double-line"></span> Quem Somos</p>
					<h2 class="sec-title">Viva o melhor de Santa Catarina</h2>
				</div>
				<div class="about-page-intro text-center">
					<p class="sec-text mb-4">
						O <strong>{SITE_NAME}</strong> nasceu da combinação de dois mundos: anos de experiência no mercado
						imobiliário catarinense e a visão de que encontrar um lançamento de qualidade em SC merecia algo
						melhor do que portais genéricos e informações desatualizadas.
					</p>
					<p class="sec-text mb-0">
						Somos um time de profissionais que conhece Santa Catarina de perto — seus bairros, suas
						construtoras, suas oportunidades. Sabemos que cada cidade tem seu ritmo, seu perfil de comprador
						e seus lançamentos com potencial real. E foi exatamente essa visão local que nos motivou a criar o
						maior portal especializado em lançamentos imobiliários do estado.
					</p>
				</div>
			</div>
		</div>
	</div>
</div>

<div class="space overflow-hidden bg-smoke">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-xl-8 col-lg-10 text-center">
				<div class="title-area mb-30">
					<p class="sub-title"><span class="double-line"></span> Propósito</p>
					<h2 class="sec-title">Nossa missão</h2>
				</div>
				<p class="sec-text mb-0">
					Conectar quem quer comprar um imóvel novo em Santa Catarina com os melhores lançamentos disponíveis —
					com informação completa, transparente e atualizada, em todas as regiões do estado.
				</p>
			</div>
		</div>
	</div>
</div>

<div class="why-sec-2 space overflow-hidden" id="why-sec" data-bg-src="/assets/img/shape/what-we-do-3-bg.png">
	<div class="container">
		<div class="row justify-content-center mb-40">
			<div class="col-xl-8 text-center">
				<div class="title-area mb-2">
					<p class="sub-title"><span class="double-line"></span> Diferenciais</p>
					<h2 class="sec-title">O que nos diferencia</h2>
				</div>
			</div>
		</div>
		<div class="row gy-30">
			{
				differentiators.map((item, index) => (
					<div class="col-xl-6">
						<div class="about-1-item h-100">
							<div class="icon">
								<img src={item.icon} alt="" />
							</div>
							<div class="content">
								<h3 class="box-title">{item.title}</h3>
								<p class="box-text">{item.text}</p>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</div>

<div class="counter-sec1 space overflow-hidden" data-bg-src="/assets/img/bg/counter-1-bg.jpg">
	<div class="container">
		<div class="row justify-content-center mb-40">
			<div class="col-xl-8 text-center">
				<div class="title-area mb-0">
					<p class="sub-title text-white"><span class="double-line"></span> Em números</p>
					<h2 class="sec-title text-white">Nossos números</h2>
				</div>
			</div>
		</div>
		<div class="counter-card-wrap style2">
			{
				stats.map((stat, index) => (
					<>
						{index > 0 && <div class="divider" />}
						<div class="counter-card fadeinup wow">
							<div class="media-body text-center">
								<h4 class="box-number">
									<span class="counter-number">{stat.value}</span>
								</h4>
								<p class="box-text">{stat.label}</p>
							</div>
						</div>
					</>
				))
			}
		</div>
	</div>
</div>

<div class="space overflow-hidden">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-xl-8 col-lg-10 text-center">
				<div class="title-area mb-30">
					<p class="sub-title"><span class="double-line"></span> Parcerias</p>
					<h2 class="sec-title">Para incorporadoras e construtoras</h2>
				</div>
				<p class="sec-text mb-4">
					O {SITE_NAME} é o canal ideal para divulgar seu lançamento para compradores qualificados em todo o
					estado. Trabalhamos com um modelo baseado em leads — você só paga quando o resultado aparece.
				</p>
				<a href="/contact" class="th-btn style2 pill">Entre em contato e cadastre seu empreendimento</a>
			</div>
		</div>
	</div>
</div>

<div class="contact-area-2 space-bottom" id="about-contact">
	<div class="container">
		<div class="row justify-content-center mb-40">
			<div class="col-xl-8 text-center">
				<div class="title-area mb-0">
					<p class="sub-title"><span class="double-line"></span> Contato</p>
					<h2 class="sec-title">Fale com a gente</h2>
					<p class="sec-text mt-3 mb-0">
						Seja você um comprador buscando o imóvel ideal ou uma incorporadora querendo divulgar um
						lançamento, estamos aqui para ajudar.
					</p>
				</div>
			</div>
		</div>
		<div class="row gy-4 justify-content-center">
			<div class="col-xl-4 col-lg-6 contact-feature-wrap">
				<div class="contact-feature">
					<div class="contact-feature-icon">
						<i class="fas fa-location-dot"></i>
					</div>
					<div class="media-body">
						<p class="contact-feature_label">Localização</p>
						<span class="contact-feature_link">Santa Catarina, Brasil</span>
					</div>
				</div>
			</div>
			<div class="col-xl-4 col-lg-6 contact-feature-wrap">
				<div class="contact-feature">
					<div class="contact-feature-icon">
						<i class="fas fa-envelope"></i>
					</div>
					<div class="media-body">
						<p class="contact-feature_label">E-mail</p>
						<a href={`mailto:${SITE_EMAIL}`} class="contact-feature_link">{SITE_EMAIL}</a>
					</div>
				</div>
			</div>
			<div class="col-xl-4 col-lg-6 contact-feature-wrap">
				<div class="contact-feature">
					<div class="contact-feature-icon">
						<i class="fab fa-whatsapp"></i>
					</div>
					<div class="media-body">
						<p class="contact-feature_label">WhatsApp</p>
						<a
							href={`https://wa.me/${SITE_WHATSAPP_NUMBER}`}
							class="contact-feature_link"
							target="_blank"
							rel="noopener noreferrer"
						>
							{SITE_PHONE_DISPLAY}
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<style>
	.about-page-intro .sec-text {
		max-width: 820px;
		margin-left: auto;
		margin-right: auto;
	}

	#about-contact .contact-feature_link {
		color: inherit;
	}

	.counter-sec1 .counter-card .box-text {
		max-width: 180px;
		margin-left: auto;
		margin-right: auto;
	}
</style>
