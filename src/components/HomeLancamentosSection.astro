---
const { properties } = Astro.props;
---

<section class="popular-sec-1 home-lancamentos-section overflow-hidden space" aria-labelledby="home-lancamentos-title">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-xl-7">
				<div class="title-area text-center mb-2">
					<p class="sub-title"><span class="double-line"></span> Lançamentos</p>
					<h2 class="sec-title mb-4" id="home-lancamentos-title">Imóveis na planta em Florianópolis</h2>
					<div class="filter-menu indicator-active filter-menu-active mt-2 justify-content-center" role="group" aria-label="Filtrar lançamentos por tipo">
						<button data-filter="*" class="th-btn tab-btn active" type="button">Ver todos</button>
						<button data-filter=".cat-apartamento" class="th-btn tab-btn" type="button">
							Apartamentos
						</button>
						<button data-filter=".cat-casa" class="th-btn tab-btn" type="button">
							Casas em condomínio
						</button>
						<button data-filter=".cat-loteamento" class="th-btn tab-btn" type="button">
							Loteamento
						</button>
					</div>
				</div>
			</div>
		</div>

		<div class="row gy-30 justify-content-center filter-active">
			{
				properties.length === 0 ? (
					<div class="col-12">
						<p class="text-center mb-0">Nenhum lançamento disponível no momento.</p>
					</div>
				) : (
					properties.map((property) => (
						<div
							class={`col-xxl-3 col-xl-4 col-lg-6 col-md-6 filter-item ${property.kindFilterClass}`}
						>
							<article class="popular-list-1 h-100">
								<div class="thumb-wrapper">
									<a href={property.detailUrl} class="thumb-link">
										<img src={property.imageUrl} alt={property.title} />
										<div class="popular-badge">
											<img src="/assets/img/icon/sell_rent_icon.svg" alt="" aria-hidden="true" />
											<p>{property.categoryLabel}</p>
										</div>
									</a>
								</div>
								<div class="property-content">
									<div class="media-body">
										<h3 class="box-title">
											<a href={property.detailUrl}>{property.title}</a>
										</h3>
										<div class="box-text">
											<div class="icon">
												<img src="/assets/img/icon/popular-location.svg" alt="" aria-hidden="true" />
											</div>
											{property.locationLabel}
										</div>
									</div>

									<ul class="property-featured">
										{property.bedrooms != null && (
											<li>
												<div class="icon">
													<img src="/assets/img/icon/bed.svg" alt="" aria-hidden="true" />
												</div>
												Quartos {property.bedrooms}
											</li>
										)}
										{property.bathrooms != null && (
											<li>
												<div class="icon">
													<img src="/assets/img/icon/bath.svg" alt="" aria-hidden="true" />
												</div>
												Banheiros {property.bathrooms}
											</li>
										)}
										{property.sizeSqm != null && (
											<li>
												<div class="icon">
													<img src="/assets/img/icon/sqft.svg" alt="" aria-hidden="true" />
												</div>
												{property.sizeSqm} m²
											</li>
										)}
									</ul>
									<div class="property-bottom">
										<h6 class="box-title">{property.priceLabel}</h6>
										<a class="th-btn sm style3 pill" href={property.detailUrl}>
											Ver mais
										</a>
									</div>
								</div>
							</article>
						</div>
					))
				)
			}
		</div>

		{
			properties.length > 0 && (
				<div class="text-center mt-40">
					<a href="/lancamentos/apartamentos" class="th-btn style3">
						Ver todos os lançamentos
					</a>
				</div>
			)
		}
	</div>
</section>

<style>
	.home-lancamentos-section .filter-item {
		display: flex;
	}

	.home-lancamentos-section .popular-list-1 {
		display: flex;
		flex-direction: column;
		width: 100%;
	}

	.home-lancamentos-section .thumb-wrapper {
		flex-shrink: 0;
		max-height: none;
		aspect-ratio: 4 / 3;
		height: auto;
	}

	.home-lancamentos-section .thumb-wrapper .thumb-link {
		display: block;
		position: relative;
		height: 100%;
	}

	.home-lancamentos-section .thumb-wrapper .thumb-link img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.home-lancamentos-section .property-content {
		display: flex;
		flex: 1;
		flex-direction: column;
	}

	.home-lancamentos-section .media-body .box-title {
		display: -webkit-box;
		min-height: 3.25rem;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		line-clamp: 2;
	}

	.home-lancamentos-section .property-featured {
		align-items: center;
		min-height: 3.25rem;
	}

	.home-lancamentos-section .property-bottom {
		margin-top: auto;
	}
</style>
