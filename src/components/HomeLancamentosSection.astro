---
import HomePropertyFilterFields from './HomePropertyFilterFields.astro';

const { properties, kinds = [], neighborhoods = [] } = Astro.props;
---

<section class="popular-sec-1 home-lancamentos-section overflow-hidden space" aria-labelledby="home-lancamentos-title">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-xl-10">
				<div class="title-area text-center mb-2">
					<p class="sub-title"><span class="double-line"></span> Lançamentos</p>
					<h2 class="sec-title mb-4" id="home-lancamentos-title">Imóveis na planta em Florianópolis</h2>
					<form class="home-lancamentos-section__filters" data-home-lancamentos-filter aria-label="Filtrar lançamentos">
						<HomePropertyFilterFields
							kinds={kinds}
							neighborhoods={neighborhoods}
							idPrefix="home-lancamentos"
							formClass="home-lancamentos-section__filter-fields"
						/>
					</form>
				</div>
			</div>
		</div>

		<div class="row gy-30 justify-content-center home-lancamentos-section__grid">
			{
				properties.length === 0 ? (
					<div class="col-12">
						<p class="text-center mb-0">Nenhum lançamento disponível no momento.</p>
					</div>
				) : (
					properties.map((property) => (
						<div
							class={`col-xxl-3 col-xl-4 col-lg-6 col-md-6 filter-item ${property.kindFilterClass} ${property.neighborhoodFilterClass || ''}`.trim()}
						>
							<article class="popular-list-1 h-100">
								<div class="thumb-wrapper">
									<a href={property.detailUrl} class="thumb-link">
										<img src={property.imageUrl} alt={property.title} />
										<div class="popular-badge">
											<img src="/assets/img/icon/sell_rent_icon.svg" alt="" aria-hidden="true" />
											<p>{property.categoryLabel}</p>
										</div>
									</a>
								</div>
								<div class="property-content">
									<div class="media-body">
										<h3 class="box-title">
											<a href={property.detailUrl}>{property.title}</a>
										</h3>
										<div class="box-text">
											<div class="icon">
												<img src="/assets/img/icon/popular-location.svg" alt="" aria-hidden="true" />
											</div>
											{property.locationLabel}
										</div>
									</div>

									<ul class="property-featured">
										{property.bedrooms != null && (
											<li>
												<div class="icon">
													<img src="/assets/img/icon/bed.svg" alt="" aria-hidden="true" />
												</div>
												Quartos {property.bedrooms}
											</li>
										)}
										{property.bathrooms != null && (
											<li>
												<div class="icon">
													<img src="/assets/img/icon/bath.svg" alt="" aria-hidden="true" />
												</div>
												Banheiros {property.bathrooms}
											</li>
										)}
										{property.sizeSqm != null && (
											<li>
												<div class="icon">
													<img src="/assets/img/icon/sqft.svg" alt="" aria-hidden="true" />
												</div>
												{property.sizeSqm} m²
											</li>
										)}
									</ul>
									<div class="property-bottom">
										<h6 class="box-title">{property.priceLabel}</h6>
										<a class="th-btn sm style3 pill" href={property.detailUrl}>
											Ver mais
										</a>
									</div>
								</div>
							</article>
						</div>
					))
				)
			}
		</div>

		<div class="home-lancamentos-section__empty text-center d-none" data-home-lancamentos-empty>
			<p class="mb-0">Nenhum lançamento encontrado com os filtros selecionados.</p>
		</div>

		{
			properties.length > 0 && (
				<div class="text-center mt-40">
					<a href="/lancamentos" class="th-btn pill home-lancamentos-section__all-btn">
						Ver todos os lançamentos
					</a>
				</div>
			)
		}
	</div>
</section>

<style>
	.home-lancamentos-section__filter-fields {
		margin-top: 8px;
		text-align: left;
	}

	.home-lancamentos-section__filters {
		margin-top: 8px;
	}

	.home-lancamentos-section .filter-item {
		display: flex;
	}

	.home-lancamentos-section .filter-item.is-filtered-out {
		display: none !important;
	}

	.home-lancamentos-section .popular-list-1 {
		display: flex;
		flex-direction: column;
		width: 100%;
	}

	.home-lancamentos-section .thumb-wrapper {
		flex-shrink: 0;
		max-height: none;
		aspect-ratio: 4 / 3;
		height: auto;
	}

	.home-lancamentos-section .thumb-wrapper .thumb-link {
		display: block;
		position: relative;
		height: 100%;
	}

	.home-lancamentos-section .thumb-wrapper .thumb-link img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.home-lancamentos-section .property-content {
		display: flex;
		flex: 1;
		flex-direction: column;
	}

	.home-lancamentos-section .media-body .box-title {
		display: -webkit-box;
		min-height: 3.25rem;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		line-clamp: 2;
	}

	.home-lancamentos-section .property-featured {
		align-items: center;
		min-height: 3.25rem;
	}

	.home-lancamentos-section .property-bottom {
		margin-top: auto;
	}

	.home-lancamentos-section__all-btn {
		padding: 14px 28px;
		font-size: 15px;
		font-weight: 600;
	}

	@media (min-width: 992px) {
		.home-lancamentos-section__filter-fields {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>

<script>
	const KIND_FILTER_CLASS = {
		apartamento: 'cat-apartamento',
		casa: 'cat-casa',
		loteamento: 'cat-loteamento',
	};

	function initHomeLancamentosFilter() {
		const section = document.querySelector('.home-lancamentos-section');

		if (!section || section.dataset.filterReady === 'true') {
			return;
		}

		const form = section.querySelector('[data-home-lancamentos-filter]');
		const kindSelect = form?.querySelector('[name="kind"]');
		const neighborhoodSelect = form?.querySelector('[name="neighborhood"]');
		const items = section.querySelectorAll('.filter-item');
		const emptyState = section.querySelector('[data-home-lancamentos-empty]');

		if (!form || !kindSelect || !neighborhoodSelect || items.length === 0) {
			return;
		}

		section.dataset.filterReady = 'true';

		const applyFilters = () => {
			const kind = kindSelect.value;
			const neighborhood = neighborhoodSelect.value;
			let visibleCount = 0;

			items.forEach((item) => {
				const matchesKind = !kind || item.classList.contains(KIND_FILTER_CLASS[kind]);
				const matchesNeighborhood = !neighborhood || item.classList.contains(`bairro-${neighborhood}`);
				const isVisible = matchesKind && matchesNeighborhood;

				item.classList.toggle('is-filtered-out', !isVisible);

				if (isVisible) {
					visibleCount += 1;
				}
			});

			if (emptyState) {
				emptyState.classList.toggle('d-none', visibleCount > 0);
				emptyState.classList.toggle('mt-40', visibleCount === 0);
			}
		};

		kindSelect.addEventListener('change', applyFilters);
		neighborhoodSelect.addEventListener('change', applyFilters);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initHomeLancamentosFilter, { once: true });
	} else {
		initHomeLancamentosFilter();
	}
</script>
