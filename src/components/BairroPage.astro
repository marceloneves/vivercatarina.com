---
import PillerLayout from '../layouts/PillerLayout.astro';
import PropertyListingTabs from './PropertyListingTabs.astro';
import { buildBairroPageContext } from '../lib/bairro-page.mjs';

const { slug, page } = Astro.props;
const context = buildBairroPageContext(slug, page);

if (!context) {
	throw new Error(`Listagem de bairro não encontrada: ${slug}`);
}
---

<PillerLayout
	title={context.seo.title}
	description={context.seo.description}
	keywords={context.seo.keywords}
	canonicalPath={context.seo.canonicalPath}
	bodyClass="bairro-listing"
	disableEffects
>
	<Fragment set:html={context.shellBefore} />
	<PropertyListingTabs
		properties={context.properties}
		allProperties={context.allProperties}
		currentPage={context.currentPage}
		totalPages={context.totalPages}
		basePath={context.basePath}
		sidebarHtml={context.sidebarHtml}
	/>
	<Fragment set:html={context.shellAfter} />
</PillerLayout>
