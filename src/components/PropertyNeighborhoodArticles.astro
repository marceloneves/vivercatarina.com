---
const { introTitle, posts } = Astro.props;
---

{
	posts.length > 0 && (
		<section class="section property-neighborhood-articles" aria-labelledby="property-neighborhood-articles-title">
			<h2 class="section__title" id="property-neighborhood-articles-title">
				{introTitle}
			</h2>
			<div class="row gy-30">
				{
					posts.map((post) => (
						<div class="col-lg-4 col-md-6 d-flex">
							<article class="blog-card property-neighborhood-articles__card">
								<div class="blog-img">
									<a href={post.href}>
										<img src={post.imageUrl} alt={post.title} loading="lazy" />
									</a>
									<div class="date">
										<time datetime={post.datePublished}>
											<a href="/blog">{post.dateLabel}</a>
										</time>
									</div>
								</div>
								<div class="blog-content">
									<div class="blog-meta">
										<a href="/blog">
											<i class="fa-solid fa-user" aria-hidden="true"></i> {post.author}
										</a>
									</div>
									<h3 class="box-title">
										<a href={post.href}>{post.title}</a>
									</h3>
									<p class="box-text">{post.excerpt}</p>
									<a href={post.href} class="th-btn pill property-neighborhood-articles__read-btn">
										Ler artigo
									</a>
								</div>
							</article>
						</div>
					))
				}
			</div>
		</section>
	)
}
