---
import { applyGlossaryInlineLinks, linkIncorporadoraWebsite } from '../lib/glossary-content-links.mjs';
import { groupGlossaryTermsByLetter } from '../lib/glossary-terms.mjs';

const groups = groupGlossaryTermsByLetter().map(({ letter, terms }) => ({
	letter,
	terms: terms.map(({ term, slug, definition, websiteUrl }) => ({
		term,
		slug,
		websiteUrl,
		definition: applyGlossaryInlineLinks(
			linkIncorporadoraWebsite(definition, websiteUrl),
			{
				excludeSlugs: websiteUrl ? [slug, 'incorporadora'] : [slug],
				skipHeadings: false,
			},
		),
	})),
}));
const introText = applyGlossaryInlineLinks(
	'Termos essenciais para quem está comprando empreendimento na planta em Florianópolis. Use a busca ou navegue por letra para entender contratos, financiamento, obras e documentação antes de fechar negócio.',
	{ skipHeadings: false },
);
---

<nav class="breadcumb-wrapper single-inventory" aria-label="Trilha de navegação">
	<div class="container">
		<div class="breadcumb-content">
			<ol class="breadcumb-menu">
				<li><a href="/">Início</a></li>
				<li><span aria-current="page">Glossário</span></li>
			</ol>
		</div>
	</div>
</nav>

<section class="space overflow-hidden glossary-page" aria-labelledby="glossary-title">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-xl-10 col-lg-11">
				<div class="title-area text-center mb-40">
					<p class="sub-title"><span class="double-line"></span> Imóveis na planta</p>
					<h1 class="sec-title" id="glossary-title">Glossário do comprador</h1>
					<p class="sec-text glossary-intro" set:html={introText} />
				</div>

				<div class="glossary-toolbar">
					<label class="glossary-search-label" for="glossary-search">Buscar termo</label>
					<input
						id="glossary-search"
						class="form-control glossary-search"
						type="search"
						placeholder="Ex.: habite-se, FGTS, planta baixa..."
						autocomplete="off"
					/>
					<nav class="glossary-letters" aria-label="Filtrar por letra">
						{
							groups.map(({ letter }) => (
								<a class="glossary-letter-link" href={`#glossary-letter-${letter}`}>
									{letter}
								</a>
							))
						}
					</nav>
				</div>

				<div class="glossary-groups" id="glossary-list">
					{
						groups.map(({ letter, terms }) => (
							<section class="glossary-group" id={`glossary-letter-${letter}`} data-letter={letter}>
								<h3 class="glossary-group-title">{letter}</h3>
								<dl class="glossary-list">
									{
										terms.map(({ term, slug, definition }) => (
											<div
												class="glossary-item"
												data-term={term.toLocaleLowerCase('pt-BR')}
											>
												<dt class="glossary-term" id={slug}>
													<a href={`#${slug}`}>{term}</a>
												</dt>
												<dd class="glossary-definition-wrap">
													<p class="glossary-definition" set:html={definition} />
												</dd>
											</div>
										))
									}
								</dl>
							</section>
						))
					}
				</div>

				<p class="glossary-empty" id="glossary-empty" hidden>Nenhum termo encontrado para a busca.</p>

				<div class="glossary-cta text-center">
					<p class="sec-text mb-3">
						Quer comparar lançamentos na planta em Florianópolis com as informações certas?
					</p>
					<a href="/lancamentos" class="th-btn style2 pill me-2 mb-2">Ver lançamentos</a>
					<a href="/contact" class="th-btn pill mb-2">Falar com especialista</a>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const searchInput = document.getElementById('glossary-search');
	const items = Array.from(document.querySelectorAll('.glossary-item'));
	const groups = Array.from(document.querySelectorAll('.glossary-group'));
	const emptyState = document.getElementById('glossary-empty');

	function normalize(value) {
		return String(value || '')
			.normalize('NFD')
			.replace(/[\u0300-\u036f]/g, '')
			.toLowerCase();
	}

	function filterGlossary() {
		const query = normalize(searchInput?.value || '');
		let visibleCount = 0;

		for (const item of items) {
			const term = normalize(item.getAttribute('data-term'));
			const definition = normalize(item.querySelector('.glossary-definition')?.textContent);
			const visible = !query || term.includes(query) || definition.includes(query);

			item.hidden = !visible;
			if (visible) {
				visibleCount += 1;
			}
		}

		for (const group of groups) {
			const hasVisibleItems = group.querySelector('.glossary-item:not([hidden])');
			group.hidden = !hasVisibleItems;
		}

		if (emptyState) {
			emptyState.hidden = visibleCount > 0;
		}
	}

	searchInput?.addEventListener('input', filterGlossary);
</script>

<style>
	.glossary-intro {
		max-width: 760px;
		margin-inline: auto;
	}

	.glossary-toolbar {
		margin-bottom: 2.5rem;
	}

	.glossary-search-label {
		display: block;
		margin-bottom: 0.5rem;
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--title-color);
	}

	.glossary-search {
		min-height: 52px;
		border-radius: 999px;
		padding-inline: 1.25rem;
		margin-bottom: 1rem;
	}

	.glossary-letters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.glossary-letter-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2rem;
		height: 2rem;
		padding-inline: 0.65rem;
		border-radius: 999px;
		background: var(--smoke-color, #f5f5f5);
		color: var(--title-color);
		font-size: 0.875rem;
		font-weight: 700;
		text-decoration: none;
		transition: background-color 0.2s ease, color 0.2s ease;
	}

	.glossary-letter-link:hover {
		background: var(--theme-color);
		color: #fff;
	}

	.glossary-group + .glossary-group {
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(3, 6, 14, 0.08);
	}

	.glossary-group-title {
		margin-bottom: 1.25rem;
		font-size: 1.75rem;
		line-height: 1;
		color: var(--theme-color);
	}

	.glossary-list {
		margin: 0;
	}

	.glossary-item + .glossary-item {
		margin-top: 1.25rem;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(3, 6, 14, 0.06);
	}

	.glossary-term {
		margin: 0 0 0.5rem;
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--title-color);
	}

	.glossary-term a {
		color: inherit;
		text-decoration: none;
	}

	.glossary-term a:hover {
		color: var(--theme-color);
	}

	.glossary-definition-wrap {
		margin: 0;
	}

	.glossary-definition {
		margin: 0;
		color: var(--body-color);
		line-height: 1.7;
	}

	.glossary-definition :global(a.glossary-external-link) {
		color: var(--theme-color);
		font-weight: 600;
		text-decoration: none;
	}

	.glossary-definition :global(a.glossary-external-link:hover) {
		text-decoration: underline;
	}

	.glossary-empty {
		margin: 0 0 2rem;
		text-align: center;
		color: var(--body-color);
	}

	.glossary-cta {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(3, 6, 14, 0.08);
	}
</style>
