---
import PillerLayout from '../layouts/PillerLayout.astro';
import PropertyLandingPage from './PropertyLandingPage.astro';
import { buildImovelPageContext } from '../lib/imovel-page.mjs';

const { slug } = Astro.props;
const page = buildImovelPageContext(slug);

	if (!page) {
		return Astro.redirect('/404');
	}
---

<PillerLayout
	title={page.seo.title}
	description={page.seo.description}
	keywords={page.seo.keywords}
	ogImage={page.seo.ogImage}
	canonicalPath={`/imovel/${page.slug}`}
	bodyClass="imovel-landing"
	disableEffects
>
	<Fragment slot="head">
		<link rel="stylesheet" href="/css/imovel-landing.css" />
		<link rel="stylesheet" href="/css/internal-links.css" />
		{page.seo.jsonLd && <script type="application/ld+json" set:html={JSON.stringify(page.seo.jsonLd)} />}
	</Fragment>

	<Fragment set:html={page.shellBefore} />
	<PropertyLandingPage page={page} />
	<Fragment set:html={page.shellAfter} />
</PillerLayout>
